#!/usr/bin/env bash

DEV_DIR="$HOME/dev"
SIDE_MODE=0

# Nerd Font icons
ICON_SESS=""
ICON_DIR=""

# 1. Handle --side flag
if [[ "$1" == "--side" ]]; then
    SIDE_MODE=1
    shift
fi

TARGET="$1"

# --- HELPER FUNCTION: Generate session name ---
# If the path is ~/dev/easy/nri, the function returns "easy_nri"
# If it's a normal external folder (e.g., /etc/nginx), it returns "nginx"
get_session_name() {
    local path="$1"
    if [[ "$path" == "$DEV_DIR/"* ]]; then
        local rel_path="${path#"$DEV_DIR/"}"
        echo "$rel_path" | tr './' '__'
    else
        basename "$path" | tr '.' '_'
    fi
}

# 2. FZF Mode
if [[ -z "$TARGET" ]]; then
    raw_sessions=$(tmux ls -F "#{session_name}" 2>/dev/null)
    
    sessions_out=""
    dirs_out=""
    
    # Enable nullglob to safely handle directories with no matches
    shopt -s nullglob
    if [[ -d "$DEV_DIR" ]]; then
        # Pure Bash: iterate over 1st and 2nd level subdirectories (safe on Mac and Linux)
        for dir in "$DEV_DIR"/* "$DEV_DIR"/*/*; do
            if [[ -d "$dir" ]]; then
                rel_path="${dir#"$DEV_DIR/"}"
                
                # Add to fzf ONLY if it's the 1st level 
                # OR if it's the 2nd level but contains a git repository
                if [[ "$rel_path" != */* ]] || [[ -d "$dir/.git" ]]; then
                    expected_sess_name=$(get_session_name "$dir")
                    
                    if echo "$raw_sessions" | grep -q "^${expected_sess_name}$"; then
                        sessions_out+="\033[32m${ICON_SESS}\033[0m ${dir}"$'\n'
                        raw_sessions=$(echo "$raw_sessions" | grep -v "^${expected_sess_name}$")
                    else
                        dirs_out+="\033[34m${ICON_DIR}\033[0m ${dir}"$'\n'
                    fi
                fi
            fi
        done
    fi
    shopt -u nullglob

    # Append remaining active sessions
    if [[ -n "$raw_sessions" ]]; then
        for s in $raw_sessions; do
            [[ -z "$s" ]] && continue
            sessions_out+="\033[32m${ICON_SESS}\033[0m $s"$'\n'
        done
    fi

    # Run FZF
    FZF_OUT=$(printf "%b%b" "$sessions_out" "$dirs_out" | grep -v '^$' | fzf --ansi --prompt="tmux> " --reverse --height=40% --print-query)
    
    # Exit if cancelled (ESC / Ctrl+C)
    [[ $? -eq 130 ]] && exit 0
    
    TARGET=$(echo "$FZF_OUT" | tail -n 1)
    [[ -z "$TARGET" ]] && exit 0

    TARGET="${TARGET/${ICON_SESS} /}"
    TARGET="${TARGET/${ICON_DIR} /}"
fi

# 3. Handle session REMOVAL (! sign at the end)
if [[ "$TARGET" == *! ]]; then
    TARGET_CLEAN="${TARGET%!}"
    
    if [[ -d "$TARGET_CLEAN" ]]; then
        SESSION_TO_KILL=$(get_session_name "$TARGET_CLEAN")
    else
        SESSION_TO_KILL=$(basename "$TARGET_CLEAN" | tr '.' '_')
    fi
    
    if tmux has-session -t "$SESSION_TO_KILL" 2>/dev/null; then
        tmux kill-session -t "$SESSION_TO_KILL"
        echo "🔪 Session '$SESSION_TO_KILL' successfully killed."
    else
        echo "ℹ️ Session '$SESSION_TO_KILL' does not exist."
    fi
    exit 0
fi

# 4. Parse session name and path (Standard flow)
if [[ -d "$TARGET" ]]; then
    DIR_PATH="$TARGET"
    SESSION_NAME=$(get_session_name "$DIR_PATH")
else
    SESSION_NAME=$(basename "$TARGET" | tr '.' '_')
    DIR_PATH=""
fi

# 5. Create base session (if it doesn't exist)
if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    if [[ -n "$DIR_PATH" ]]; then
        tmux new-session -d -s "$SESSION_NAME" -c "$DIR_PATH"
    else
        tmux new-session -d -s "$SESSION_NAME"
    fi
fi

# 6. Attach (grouped or standard)
if [[ $SIDE_MODE -eq 1 ]]; then
    SIDE_NAME="${SESSION_NAME}-side-$(date +%s)"
    
    tmux new-session -d -t "$SESSION_NAME" -s "$SIDE_NAME"
    tmux set-option -t "$SIDE_NAME" destroy-unattached on

    if [[ -z "$TMUX" ]]; then
        tmux attach-session -t "$SIDE_NAME"
    else
        tmux switch-client -t "$SIDE_NAME"
    fi
else
    if [[ -z "$TMUX" ]]; then
        tmux attach-session -t "$SESSION_NAME"
    else
        tmux switch-client -t "$SESSION_NAME"
    fi
fi
