{
  "Helm if": {
    "prefix": "h-if",
    "description": "Helm if/end block",
    "body": [
      "{{- if ${1:.Values.enabled} }}",
      "${0}",
      "{{- end }}"
    ]
  },
  "Helm if-else": {
    "prefix": "h-ifelse",
    "description": "Helm if/else/end block",
    "body": [
      "{{- if ${1:.Values.enabled} }}",
      "${0}",
      "{{- else }}",
      "${2}",
      "{{- end }}"
    ]
  },
  "Helm range": {
    "prefix": "h-range",
    "description": "Helm range over a list",
    "body": [
      "{{- range ${1:.Values.items} }}",
      "${0}",
      "{{- end }}"
    ]
  },
  "Helm with": {
    "prefix": "h-with",
    "description": "Helm with block (scopes . to value)",
    "body": [
      "{{- with ${1:.Values.section} }}",
      "${0}",
      "{{- end }}"
    ]
  },
  "Helm define": {
    "prefix": "h-define",
    "description": "Helm named template definition",
    "body": [
      "{{- define \"${1:chart.fullname}\" -}}",
      "${0}",
      "{{- end }}"
    ]
  },
  "Helm include": {
    "prefix": "h-include",
    "description": "Helm include named template with nindent",
    "body": [
      "{{- include \"${1:chart.fullname}\" . | nindent ${2:4} }}"
    ]
  },
  "Helm toYaml": {
    "prefix": "h-toyaml",
    "description": "toYaml with nindent for embedding values blocks",
    "body": [
      "{{- toYaml ${1:.Values.section} | nindent ${2:8} }}"
    ]
  },
  "Helm required": {
    "prefix": "h-required",
    "description": "Helm required — fail if value is empty",
    "body": [
      "{{ required \"${1:A value for .Values.key is required}\" ${2:.Values.key} }}"
    ]
  },
  "Helm tpl": {
    "prefix": "h-tpl",
    "description": "Helm tpl — render a value as a template",
    "body": [
      "{{ tpl ${1:.Values.template} . }}"
    ]
  },
  "Helm lookup": {
    "prefix": "h-lookup",
    "description": "Helm lookup existing cluster resource",
    "body": [
      "{{- $${1:existing} := lookup \"${2:v1}\" \"${3:Secret}\" \"${4:.Release.Namespace}\" \"${5:name}\" -}}"
    ]
  },
  "Helm template header": {
    "prefix": "h-file",
    "description": "Standard Helm template file with metadata and labels",
    "body": [
      "apiVersion: ${1:apps/v1}",
      "kind: ${2:Deployment}",
      "metadata:",
      "  name: {{ include \"${3:chart.fullname}\" . }}",
      "  namespace: {{ .Release.Namespace }}",
      "  labels:",
      "    {{- include \"${3:chart.labels}\" . | nindent 4 }}",
      "spec:",
      "  ${0}"
    ]
  }
}
