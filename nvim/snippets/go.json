{
  "if err": {
    "prefix": "iferr",
    "description": "if err != nil",
    "body": ["if err != nil {", "\t${0:return err}", "}"]
  },
  "return wrapped error": {
    "prefix": "errw",
    "description": "return fmt.Errorf with wrapped error",
    "body": [
      "if err != nil {",
      "\treturn fmt.Errorf(\"${1:message}: %w\", err)",
      "}"
    ]
  },
  "HTTP handler": {
    "prefix": "httphandler",
    "description": "net/http handler function",
    "body": [
      "func ${1:handler}(w http.ResponseWriter, r *http.Request) {",
      "\t${0}",
      "}"
    ]
  },
  "HTTP handler method": {
    "prefix": "httphandlerm",
    "description": "net/http handler method",
    "body": [
      "func (${1:h} *${2:Handler}) ${3:Handle}(w http.ResponseWriter, r *http.Request) {",
      "\t${0}",
      "}"
    ]
  },
  "test function": {
    "prefix": "test",
    "description": "testing function",
    "body": ["func Test${1:Name}(t *testing.T) {", "\t${0}", "}"]
  },
  "subtest": {
    "prefix": "tRun",
    "description": "t.Run subtest",
    "body": ["t.Run(\"${1:name}\", func(t *testing.T) {", "\t${0}", "})"]
  },
  "table test": {
    "prefix": "tt",
    "description": "table-driven test",
    "body": [
      "tests := []struct {",
      "\tname string",
      "\t${1:input} ${2:string}",
      "\twant ${3:string}",
      "}{",
      "\t{",
      "\t\tname: \"${4:name}\",",
      "\t\t${1:input}: ${5:\"input\"},",
      "\t\twant: ${6:\"want\"},",
      "\t},",
      "}",
      "",
      "for _, tt := range tests {",
      "\tt.Run(tt.name, func(t *testing.T) {",
      "\t\t${0}",
      "\t})",
      "}"
    ]
  },
  "select with ctx": {
    "prefix": "selectctx",
    "description": "select statement",
    "body": [
      "select {",
      "case ${1:v} := <-${2:ch}:",
      "\t${0:_ = ${1:v}}",
      "case <-${3:ctx}.Done():",
      "\treturn ${3:ctx}.Err()",
      "}"
    ]
  },
  "controller reconcile": {
    "prefix": "reconcile",
    "description": "controller-runtime Reconcile method",
    "body": [
      "func (r *${1:Kind}Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {",
      "\tlog := ctrl.LoggerFrom(ctx).WithValues(\"name\", req.NamespacedName)",
      "\t_ = log",
      "",
      "\t${0:return ctrl.Result{}, nil}",
      "}"
    ]
  },
  "controller get object": {
    "prefix": "kget",
    "description": "controller-runtime client Get with IgnoreNotFound",
    "body": [
      "var ${1:obj} ${2:appv1.MyKind}",
      "if err := r.Get(ctx, req.NamespacedName, &${1:obj}); err != nil {",
      "\treturn ctrl.Result{}, client.IgnoreNotFound(err)",
      "}",
      "${0}"
    ]
  },
  "controller set owner": {
    "prefix": "ownerref",
    "description": "controller-runtime SetControllerReference",
    "body": [
      "if err := ctrl.SetControllerReference(&${1:owner}, &${2:child}, r.Scheme); err != nil {",
      "\treturn ctrl.Result{}, err",
      "}",
      "${0}"
    ]
  }
}
